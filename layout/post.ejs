<%- partial('partial/helpers') %>
<div class="mingyue-shell post-shell">
  <article class="column post-column">
    <h1 class="column-title post-page-title"><%= format_bracket_title(page.title) %></h1>
    <%- partial('partial/post-meta', {
      post: page,
      options: { show_date: true, show_tags: true },
      format_bracket_title: format_bracket_title
    }) %>
    <div class="post-content">
      <%- page.content %>
    </div>
  </article>

  <%- partial('partial/bio') %>
</div>
