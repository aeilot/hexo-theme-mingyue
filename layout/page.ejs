<%- partial('partial/helpers') %>
<div class="mingyue-shell page-shell unified-shell">
  <article class="column post-column unified-content">
    <h1 class="column-title post-page-title"><%= format_bracket_title(page.title) %></h1>
    <div class="post-content">
      <%- page.content %>
    </div>
  </article>

  <%- partial('partial/title-panel', {
    panel_title: config.title,
    panel_desc: (theme.bio && theme.bio.description) ? theme.bio.description : '',
    panel_class: 'home-title-panel--post',
    show_nav: true
  }) %>
</div>
